# ── Required ─────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=       # Vercel Blob storage token
ADMIN_TOKEN=                 # Secret token for admin API endpoints

# ── Optional: OpenSea Integration ────────────────────────
OPENSEA_API_KEY=             # OpenSea API key for Emblem Vault sales data

# ── Optional: Community Submission Notifications ─────────
TELEGRAM_BOT_TOKEN=          # Telegram bot token (from @BotFather)
TELEGRAM_CHAT_ID=            # Telegram chat/group ID for notifications

# ── Optional: Email Notifications ────────────────────────
RESEND_API_KEY=              # Resend.com API key for email alerts
NOTIFICATION_EMAIL=          # Email address for submission notifications
